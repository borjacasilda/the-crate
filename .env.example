# The Crate — environment configuration.
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real credentials.
#
# Only the Postgres block is REQUIRED. Everything else is optional and unlocks an
# extra feature (Discogs enrichment, the local AI assistant, live web lookups…).

# ════════════════════════════════════════════════════════════════════
#  REQUIRED — PostgreSQL + pgvector
# ════════════════════════════════════════════════════════════════════
# Consumed by BOTH docker-compose.yml (to create the DB) and database.py (to
# connect). POSTGRES_DB is fixed to `vinylid` in docker-compose.yml, so you
# normally only choose a user and password.
POSTGRES_DB=vinylid
POSTGRES_USER=vinylid
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Where database.py reaches the container. With the default docker-compose setup
# the DB is published on localhost; remap DB_PORT if 5432 is already taken.
DB_HOST=localhost
DB_PORT=5432

# ════════════════════════════════════════════════════════════════════
#  OPTIONAL — local AI assistant (Ollama)
# ════════════════════════════════════════════════════════════════════
# The in-app assistant talks to a local Ollama server. Leave unset to use the
# default; the assistant simply stays offline until Ollama is running.
# OLLAMA_HOST=http://127.0.0.1:11434

# ════════════════════════════════════════════════════════════════════
#  OPTIONAL — Discogs enrichment (cover art, label, year, styles)
# ════════════════════════════════════════════════════════════════════
# Create a token at https://www.discogs.com/settings/developers
# A personal access token is enough; the consumer key/secret pair also works.
# DISCOGS_ACCESS_TOKEN=your_personal_access_token
# DISCOGS_CONSUMER_KEY=your_consumer_key
# DISCOGS_CONSUMER_SECRET=your_consumer_secret

# ════════════════════════════════════════════════════════════════════
#  OPTIONAL — tuning knobs (sensible defaults baked in; override only if needed)
# ════════════════════════════════════════════════════════════════════
# THECRATE_MAX_LEVEL=5                       # cap the analysis pipeline level (1–5)
# THECRATE_HARMONIC_CONTINUOUS=1             # 0 = legacy binary harmonic gate
# THECRATE_RA_GRAPHQL=https://ra.co/graphql  # Resident Advisor endpoint (live events)
# THECRATE_WEB_SOURCES=es.ra.co              # comma list of domains for reference search
# THECRATE_VINYL_STORES=hardwax              # comma list of record-shop adapters
# THECRATE_KB_MAX_CHUNKS=5000                # knowledge-base size cap
# THECRATE_KB_MAX_FILE_MB=20                 # per-file ingest cap
# THECRATE_WEB_CACHE_MAX=2000                # web-source cache cap
# THECRATE_COVERS_DIR=./covers               # cover-art store
# THECRATE_RECORDINGS_DIR=./recordings       # full-take archive

# ════════════════════════════════════════════════════════════════════
#  RESERVED — planned features (keys recognised but not yet wired)
# ════════════════════════════════════════════════════════════════════
# GOGLE_API=your_key             # reserved: planned Google multimodal embeddings
# REDDIT_CLIENT_ID=your_id       # reserved: planned community-sentiment tool
# REDDIT_CLIENT_SECRET=your_secret
